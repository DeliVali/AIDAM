{
  "name": "aidam-escritorio",
  "productName": "AIDAM",
  "version": "0.1.0",
  "description": "AIDAM — verificación abierta de información (aplicación de escritorio)",
  "author": {
    "name": "Jeffrey Romero Del Val",
    "email": "delvaljeffrey@gmail.com"
  },
  "homepage": "https://github.com/DeliVali/AIDAM",
  "license": "Apache-2.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "empaquetar": "electron-builder --linux"
  },
  "build": {
    "appId": "dev.delivali.aidam",
    "productName": "AIDAM",
    "files": [
      "main.js",
      "icono.svg",
      "build/icon.png"
    ],
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Utility",
      "synopsis": "Verificación abierta de información",
      "desktop": {
        "entry": {
          "Name": "AIDAM",
          "Comment": "Verificación abierta de información",
          "Keywords": "fact-checking;verificación;noticias;"
        }
      }
    },
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "license": "../LICENSE"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "icon": "build/icon.png",
      "category": "public.app-category.utilities"
    },
    "publish": {
      "provider": "github",
      "owner": "DeliVali",
      "repo": "AIDAM"
    },
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "devDependencies": {
    "electron": "43.1.1",
    "electron-builder": "26.15.3"
  }
}
